ENV=development

#  Order Service (port 50051)
ORDER_DATA_SOURCE_URL=postgres://postgres:123456@127.0.0.1:5432/order?sslmode=disable
ORDER_APPLICATION_PORT=50051
ORDER_PAYMENT_SERVICE_URL=localhost:50052

#  Payment Service (port 50052)
PAYMENT_DATA_SOURCE_URL=postgres://postgres:123456@127.0.0.1:5432/payment?sslmode=disable
PAYMENT_APPLICATION_PORT=50052

#  Product Service (port 50053)
PRODUCT_DATA_SOURCE_URL=postgres://postgres:123456@127.0.0.1:5432/product?sslmode=disable
PRODUCT_APPLICATION_PORT=50053
PRODUCT_REDIS_URL=redis://127.0.0.1:6379/0

#  Auth Service (port 50054)
AUTH_DATA_SOURCE_URL=postgres://postgres:123456@127.0.0.1:5432/auth?sslmode=disable
AUTH_APPLICATION_PORT=50054
AUTH_JWT_SECRET=your-secret-key-change-me

#  Gateway (port 8080)
GATEWAY_APPLICATION_PORT=8080
GATEWAY_ORDER_SERVICE_URL=localhost:50051
GATEWAY_PAYMENT_SERVICE_URL=localhost:50052
GATEWAY_AUTH_SERVICE_URL=localhost:50054
GATEWAY_RATE_LIMIT_REQUESTS=100
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

#  Docker PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5432

#  Docker Redis
REDIS_PORT=6379
